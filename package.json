{
  "name": "planora-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "start:bun": "bun src/index.ts",
    "db:migrate": "bunx prisma migrate deploy",
    "db:seed": "bunx prisma db seed",
    "postinstall": "bunx prisma generate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "ts-node-dev": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "prisma": "^7.5.0",
    "stripe": "^20.4.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
